# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# LiteLLM proxy backend (infra/litellm-proxy/) — escolha UM dos dois blocos.
# O proxy traduz Anthropic <-> OpenAI, permitindo que o Claude Code use
# qualquer backend compativel sem saber.
# ─────────────────────────────────────────────────────────────────────────────

# Opcao A — backend OpenWebUI (default em litellm-config.yaml)
# Gere a chave em https://chat.alia.atlantico.com.br -> Settings -> Account -> API Keys
OPENWEBUI_API_KEY=sk-your_openwebui_key_here
OPENWEBUI_BASE_URL=https://chat.alia.atlantico.com.br/api

# Opcao B — backend Anthropic direto (legado; troque litellm-config.yaml de
# volta para model "anthropic/claude-*" + api_key ANTHROPIC_API_KEY_BACKEND)
# ANTHROPIC_API_KEY_BACKEND=your_anthropic_backend_key_here

# Optional: route SDK/clients through local LiteLLM proxy
# ANTHROPIC_BASE_URL=http://localhost:4000

# Model configuration — UMA variável controla o modelo usado em TODO o sistema.
# Precedência efetiva (ver core/agents/memory/config_loader.get_agent_model e
# core/utils/config.get_default_model):
#   1. LLM_MODEL (genérico, preferido)
#   2. ANTHROPIC_MODEL (legado, mantido por compatibilidade)
#   3. model: do YAML do agente (core/config/agents/*.yaml)
#   4. DEFAULT_MODEL (fallback final em core/utils/config.py)
#
# Haiku costuma ser suficiente para todos os agentes na POC. Para usar Sonnet
# ou Opus, troque só aqui e reinicie o Streamlit.
LLM_MODEL=claude-3-5-haiku-20241022

# Exemplos (descomentar apenas um):
# LLM_MODEL=claude-haiku-4-5-20251001        # Haiku 4.5
# LLM_MODEL=claude-sonnet-4-5                # Sonnet 4.5 — mais caro, melhor raciocínio
# LLM_MODEL=claude-3-5-sonnet-20241022       # Sonnet 3.5 (compatível)

# Compatibilidade legada (não remover se .env antigo já usava esse nome).
# Se ambos estiverem definidos, LLM_MODEL vence.
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional: Debug mode
# DEBUG=False

# Currency configuration (Epic 5.1)
# Set to BRL to display costs in Brazilian Reais
CURRENCY=BRL
USD_TO_BRL_RATE=5.5
